# Normalize line endings to LF in the repo; prevents CRLF churn from Windows editors.
* text=auto eol=lf

# Explicitly treat web/source/text assets as LF text
*.html  text eol=lf
*.htm   text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.svg   text eol=lf
*.htaccess text eol=lf

# Treat known binaries as binary (never normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
*.gz    binary
